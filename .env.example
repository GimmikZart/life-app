# Supabase
# Use local Supabase values when running `supabase start`.
# Copy the anon and service_role keys from `supabase status`.
SUPABASE_URL="http://127.0.0.1:53321"
SUPABASE_KEY="your-local-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-local-service-role-key"

# Nuxt public runtime variables for browser-side Supabase usage.
# Keep this key equal to the local anon key above.
NUXT_PUBLIC_SUPABASE_URL="http://127.0.0.1:53321"
NUXT_PUBLIC_SUPABASE_KEY="your-local-anon-key"

# PostgreSQL connection string for Drizzle.
# Local Supabase default:
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:53322/postgres"
# Cloud example:
# DATABASE_URL="postgresql://postgres:[password]@db.your-project-ref.supabase.co:5432/postgres"

# Google Calendar OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:3000/api/auth/google/callback"

# Microsoft Graph OAuth
MICROSOFT_CLIENT_ID=""
MICROSOFT_CLIENT_SECRET=""
MICROSOFT_TENANT_ID="common"
MICROSOFT_REDIRECT_URI="http://localhost:3000/api/auth/microsoft/callback"

# External calendar sync
# Generate a long random value and keep it stable, otherwise saved provider tokens
# cannot be decrypted after restart/deploy.
EXTERNAL_CALENDAR_TOKEN_SECRET=""
# Public HTTPS base URL used by Google/Microsoft webhooks. Leave empty in local
# development and use manual sync from the UI.
EXTERNAL_CALENDAR_WEBHOOK_BASE_URL=""
EXTERNAL_CALENDAR_SYNC_PAST_DAYS="365"
EXTERNAL_CALENDAR_SYNC_FUTURE_DAYS="365"
